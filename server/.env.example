# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (the Next.js app)
CORS_ORIGINS=http://localhost:3000

# --- Database (Neon PostgreSQL) ---
# Pooled connection string used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection used by Prisma Migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# --- AI grading (Google Gemini) ---
GEMINI_API_KEY=""
# Cost ceiling / rate limiting for Writing & Speaking grading
GEMINI_MAX_CALLS_PER_MINUTE=30
GEMINI_MONTHLY_CALL_CEILING=20000
