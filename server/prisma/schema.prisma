// Lexora data model — canonical entities per CLAUDE_RULES.md + the V2 spec docs.
// Locked definitions this schema enforces:
//  - Per-skill, never blended: all scoring is per SkillArea (all SIX skills equal).
//  - Content created ONCE, assigned to MANY groups (Task ↔ Group via Assignment).
//  - Access is group-level by default with additive per-student overrides.
//  - Group moves preserve history (Result/Streak/points reference User, not Group).
//  - Permission checks by ROLE, never by account existence (Teacher/Admin merged, splittable).
//  - Tunable thresholds live in config, NOT here (see src/config).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

// Teacher and Admin are merged for v1 but kept as distinct enum values so the
// role can split later without a data migration. Permission checks read role.
enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Level {
  BEGINNER
  ELEMENTARY
  PRE_IELTS
  IELTS_INTRODUCTION
  IELTS_GRADUATION
}

// All six skills are first-class and treated equally in progress/trends/ranking.
enum SkillArea {
  GRAMMAR
  VOCABULARY
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum TaskCategory {
  PRACTICE // untimed, retakeable, does NOT affect rank
  HOMEWORK // assigned, has due context
  TEST // timed, scored, single-attempt by default, feeds rank
  EXTRA_PRACTICE // optional, self-directed, always available
}

// Question formats reuse PRACTICE_TYPES content across practice, homework, tests.
enum QuestionFormat {
  MULTIPLE_CHOICE_SINGLE
  MULTIPLE_CHOICE_MULTI
  GAP_FILL
  MATCHING
  REORDERING
  TRANSLATION_UZ_EN // fuzzy/keyword matching, low-confidence queued for teacher check
  VOCAB_EXAMPLE_SENTENCE // auto, word-usage, keyword+pattern
  WRITING_SENTENCE // AI-graded, grammar accuracy
  WRITING_EXTENDED // AI-graded essay/paragraph
  SPEAKING_AUDIO // AI-graded, requires audio infra
  SHORT_ANSWER
}

// Two independent test dimensions: Skill Scope + Test Purpose (always one of each).
enum TestSkillScope {
  GRAMMAR
  VOCABULARY
  READING
  LISTENING
  MIXED
}

enum TestPurpose {
  UNIT
  MONTHLY
  PLACEMENT // excluded from ranking, streaks, progress trends (diagnostic)
  CUSTOM
}

// Per-student-per-item vocabulary state machine (NOT full SRS). Thresholds in config.
enum VocabState {
  NEW // unpracticed
  LEARNING // < 3 correct
  REVIEWED // 3+ correct, not yet mastered
  MASTERED // 3 consecutive correct across >= 2 separate sessions
  WEAK // last attempt wrong OR < 60% over last 5 (mastered can regress to weak)
}

// Auto-graded sections finalize immediately; Writing/Speaking stay PENDING_REVIEW
// until AI scoring completes — never show an incomplete score as final.
enum ResultStatus {
  COMPLETED
  PENDING_REVIEW
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

// ----------------------------------------------------------------------------
// Identity & grouping
// ----------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String? // null for pure Google OAuth accounts
  googleId     String?   @unique
  role         Role      @default(STUDENT)
  firstName    String
  lastName     String
  // Students belong to at most one group at a time; teachers have none.
  groupId      String?
  group        Group?    @relation("GroupMembers", fields: [groupId], references: [id])
  lastActiveAt DateTime? // drives "active" window + falling-behind inactivity flag
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Authored content (teacher)
  createdTasks         Task[]           @relation("TaskAuthor")
  createdVocabSets     VocabularySet[]  @relation("VocabSetAuthor")
  createdTests         Test[]           @relation("TestAuthor")
  givenFeedback        Feedback[]       @relation("FeedbackAuthor")

  // Student activity
  attempts        Attempt[]
  results         Result[]
  vocabStates     StudentVocabItemState[]
  taskOverrides   StudentTaskOverride[]
  receivedFeedback Feedback[]           @relation("FeedbackStudent")
  badgeUnlocks    BadgeUnlock[]
  pointsLedger    PointsLedgerEntry[]
  streak          Streak?

  @@index([groupId])
  @@index([role])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  level     Level
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     User[]              @relation("GroupMembers")
  assignments Assignment[]
  challenges  WeeklyChallenge[]

  @@index([level])
}

// ----------------------------------------------------------------------------
// Textbook hierarchy: Book -> Unit -> Lesson (optional) -> Topic (reusable tag)
// ----------------------------------------------------------------------------

model Textbook {
  id        String   @id @default(cuid())
  title     String
  level     Level?
  createdAt DateTime @default(now())

  units Unit[]
}

model Unit {
  id         String   @id @default(cuid())
  textbookId String
  textbook   Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)
  title      String
  order      Int      @default(0)

  lessons Lesson[]
  tasks   Task[]

  @@index([textbookId])
}

// Lesson is OPTIONAL in the hierarchy — some books skip it.
model Lesson {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  title  String
  order  Int    @default(0)

  tasks Task[]

  @@index([unitId])
}

// Topic is a reusable cross-book tag shared by textbook tasks AND vocabulary.
// Enables topic-level weak-area tracking (sharper than skill-level).
model Topic {
  id   String @id @default(cuid())
  name String @unique

  tasks     Task[]          @relation("TaskTopics")
  vocabItems VocabularyItem[] @relation("VocabItemTopics")
  results   ResultTopic[]
}

// ----------------------------------------------------------------------------
// Content: Task (created once) + Questions. Tests reuse the same content.
// ----------------------------------------------------------------------------

model Task {
  id          String       @id @default(cuid())
  title       String
  category    TaskCategory
  skillArea   SkillArea
  // Textbook placement is optional metadata — a Task is a reusable content item,
  // not owned by one book. Topics (many-to-many) drive cross-book reuse.
  unitId      String?
  unit        Unit?        @relation(fields: [unitId], references: [id])
  lessonId    String?
  lesson      Lesson?      @relation(fields: [lessonId], references: [id])
  // Teacher notes are teacher-only and MUST stay separate from student instructions.
  instructions String? // shown to students
  teacherNotes String? // teacher-only
  createdById String
  createdBy   User         @relation("TaskAuthor", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  topics      Topic[]      @relation("TaskTopics")
  questions   Question[]
  assignments Assignment[]
  attempts    Attempt[]
  testItems   TestItem[]
  overrides   StudentTaskOverride[]

  @@index([category])
  @@index([skillArea])
  @@index([unitId])
}

model Question {
  id         String         @id @default(cuid())
  taskId     String
  task       Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  order      Int            @default(0)
  format     QuestionFormat
  skillArea  SkillArea
  prompt     String
  // Format-specific payload (options, pairs, media refs) kept as JSON for flexibility.
  content    Json
  // Auto-graded: exact/accepted answers. Writing/Speaking: scoring RUBRIC (feeds AI).
  answerKey  Json
  points     Int            @default(1)

  answers AttemptAnswer[]

  @@index([taskId])
}

// ----------------------------------------------------------------------------
// Assignment: one content item -> many groups, with additive per-student overrides
// ----------------------------------------------------------------------------

model Assignment {
  id         String           @id @default(cuid())
  taskId     String
  task       Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  status     AssignmentStatus @default(ASSIGNED)
  dueAt      DateTime? // homework due context
  assignedAt DateTime         @default(now())

  @@unique([taskId, groupId])
  @@index([groupId])
}

// Additive per-student access grants (grant EXTRA content beyond group baseline;
// never restrict below it).
model StudentTaskOverride {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@unique([studentId, taskId])
  @@index([studentId])
}

// ----------------------------------------------------------------------------
// Tests: reuse Task/Question content in a timed, scored context.
// Classified by TWO independent dimensions: skill scope + purpose.
// ----------------------------------------------------------------------------

model Test {
  id           String         @id @default(cuid())
  title        String
  skillScope   TestSkillScope
  purpose      TestPurpose
  timeLimitSec Int? // timed context
  createdById  String
  createdBy    User           @relation("TestAuthor", fields: [createdById], references: [id])
  createdAt    DateTime       @default(now())

  items    TestItem[]
  attempts Attempt[]
}

// Ordered inclusion of reusable Tasks into a Test (content reuse, not duplication).
model TestItem {
  id     String @id @default(cuid())
  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  taskId String
  task   Task   @relation(fields: [taskId], references: [id])
  order  Int    @default(0)

  @@unique([testId, taskId])
  @@index([testId])
}

// ----------------------------------------------------------------------------
// Vocabulary: Set (assignable, created once) -> Item -> per-student state
// ----------------------------------------------------------------------------

model VocabularySet {
  id          String   @id @default(cuid())
  title       String
  level       Level?
  createdById String
  createdBy   User     @relation("VocabSetAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  items VocabularyItem[]
}

model VocabularyItem {
  id            String  @id @default(cuid())
  setId         String
  set           VocabularySet @relation(fields: [setId], references: [id], onDelete: Cascade)
  word          String
  meaningEn     String
  translationUz String
  synonym       String?
  exampleSentence String?
  collocation   String?
  pronunciation String? // IPA by default
  audioUrl      String? // optional
  wordForm      String?

  topics       Topic[]                 @relation("VocabItemTopics")
  studentStates StudentVocabItemState[]

  @@index([setId])
}

// Per-student-per-item tracking (recall accuracy per word), NOT set completed/not.
model StudentVocabItemState {
  id              String     @id @default(cuid())
  studentId       String
  student         User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  itemId          String
  item            VocabularyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  state           VocabState @default(NEW)
  consecutiveCorrect Int     @default(0)
  distinctSessionsCorrect Int @default(0)
  totalAttempts   Int        @default(0)
  correctAttempts Int        @default(0)
  // Rolling window (last 5 outcomes) used to compute the WEAK flag, per config.
  lastFiveOutcomes Boolean[] @default([])
  lastAttemptAt   DateTime?
  updatedAt       DateTime   @updatedAt

  @@unique([studentId, itemId])
  @@index([studentId, state])
}

// ----------------------------------------------------------------------------
// Attempts & Results: scored PER SKILL, never blended
// ----------------------------------------------------------------------------

model Attempt {
  id          String    @id @default(cuid())
  studentId   String
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // An attempt is against a Task (practice/homework) OR a Test — exactly one.
  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id])
  testId      String?
  test        Test?     @relation(fields: [testId], references: [id])
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  answers AttemptAnswer[]
  result  Result?

  @@index([studentId])
  @@index([taskId])
  @@index([testId])
}

model AttemptAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  response   Json // student's raw answer (text, selected ids, audio ref, etc.)
  isCorrect  Boolean? // null while pending AI review
  awardedPoints Int   @default(0)
  // Fuzzy translation / low-confidence matches flagged for a quick teacher check.
  needsTeacherCheck Boolean @default(false)
  aiFeedback String?

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model Result {
  id        String       @id @default(cuid())
  attemptId String       @unique
  attempt   Attempt      @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  studentId String
  student   User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    ResultStatus @default(COMPLETED)
  // Placement results are excluded from ranking/streaks/progress (diagnostic only).
  excludedFromProgress Boolean @default(false)
  createdAt DateTime     @default(now())

  skillScores  ResultSkillScore[]
  topicMisses  ResultTopic[]

  @@index([studentId, createdAt])
}

// Per-skill breakdown of a single result (a mixed test has several rows).
model ResultSkillScore {
  id           String    @id @default(cuid())
  resultId     String
  result       Result    @relation(fields: [resultId], references: [id], onDelete: Cascade)
  skillArea    SkillArea
  correctCount Int
  totalCount   Int
  // Stored as a fraction 0..1; percentage computed at read time.
  accuracy     Float

  @@unique([resultId, skillArea])
}

// Mistakes link to Topic (not just skill) so weak-area tracking is topic-level.
model ResultTopic {
  id        String @id @default(cuid())
  resultId  String
  result    Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
  topicId   String
  topic     Topic  @relation(fields: [topicId], references: [id])
  missCount Int    @default(0)

  @@unique([resultId, topicId])
}

// ----------------------------------------------------------------------------
// Motivation layer (config-driven): Badges, Points, Streak, Challenges, Feedback
// ----------------------------------------------------------------------------

// Generic milestone-unlock pattern so new badges need no one-off logic.
model Badge {
  id          String     @id @default(cuid())
  code        String     @unique // stable identifier referenced by config
  name        String
  description String
  skillArea   SkillArea? // null = cross-skill (streak, most-improved, unit-master)
  threshold   Int // count within skill/activity type that unlocks it

  unlocks BadgeUnlock[]
}

model BadgeUnlock {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([studentId, badgeId])
  @@index([studentId])
}

// Append-only points ledger. Anti-gaming: uniqueKey enforces "awarded once per
// unique meaningful action" (re-reviewing/re-practising mastered gives no points).
model PointsLedgerEntry {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reason    String // maps to a configured point-value key
  points    Int
  uniqueKey String? // dedupe key for once-per-action actions
  createdAt DateTime @default(now())

  @@unique([studentId, uniqueKey])
  @@index([studentId, createdAt])
}

// Streak counts SCHEDULED-SESSION days (odd/even schedule), NOT calendar days.
model Streak {
  id             String    @id @default(cuid())
  studentId      String    @unique
  student        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentLength  Int       @default(0)
  longestLength  Int       @default(0)
  lastSessionDay DateTime?
  updatedAt      DateTime  @updatedAt
}

// System-generated from a rotating template pool by default; teacher can override.
model WeeklyChallenge {
  id          String   @id @default(cuid())
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  templateKey String
  title       String
  description String
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())

  @@index([groupId])
}

// Short comments attached to a specific test/task result (v1 feedback), not essays.
model Feedback {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("FeedbackStudent", fields: [studentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("FeedbackAuthor", fields: [authorId], references: [id])
  resultId  String?
  body      String
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}
