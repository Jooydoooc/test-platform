# Lexora — environment variables. Copy to .env.local and fill in.
# Never commit real values. .env.local is gitignored.

# --- Supabase ---------------------------------------------------------------
# From the Supabase project dashboard -> Project Settings -> API.
# URL + anon key are exposed to the browser (NEXT_PUBLIC_*) — that is expected;
# Row Level Security is the real enforcement, so the anon key is safe to ship.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER-ONLY. Bypasses RLS. Used for grading writes and admin actions.
# Never prefix with NEXT_PUBLIC_ and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI grading (Writing/Speaking) — see CLAUDE_RULES.md --------------------
# GEMINI_API_KEY=your-gemini-key

# --- Telegram integration (existing) ---------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
